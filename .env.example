# ============================================================
# MVP Auto-Summary — Environment Variables
# Copy to .env and fill in actual values:
#   cp .env.example .env
# ============================================================

# --- General ---
TIMEZONE=Europe/Moscow

# --- n8n ---
N8N_PORT=5678
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_STRONG_PASSWORD
N8N_ENCRYPTION_KEY=GENERATE_32_CHAR_RANDOM_STRING
N8N_WEBHOOK_URL=http://YOUR_VPS_IP:5678

# --- PostgreSQL ---
POSTGRES_PORT=5432
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=n8n

# --- STT (Транскрипция) ---
# ❗ Yandex SpeechKit временно отключён (2026-03-01, оптимизация расходов)
# См. E100 в docs/ERRORS.md и раздел 17 в docs/SPECS.md для вариантов замены
YANDEX_API_KEY=DISABLED
TRANSCRIBE_PORT=9001

# --- Whisper (self-hosted STT, бесплатная альтернатива) ---
# Модель: tiny|base|small|medium|large-v3
# medium = оптимально для русского (+3 GB RAM)
WHISPER_PORT=9000
WHISPER_MODEL=medium

# --- GLM-4 (ZhipuAI) ---
GLM4_API_KEY=YOUR_ZHIPUAI_API_KEY
GLM4_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM4_MODEL=glm-4-flash

# --- Dify.ai (RAG) ---
# API-ключ получить: Dify UI → Settings → API Keys
DIFY_API_KEY=YOUR_DIFY_API_KEY
# Внешний URL Dify (API для n8n)
DIFY_BASE_URL=http://84.252.100.93:8080
# ID общего датасета (фаллбэк, если lead-специфичный не найден)
DIFY_DATASET_ID=ba120e09-0119-438f-b6d6-884e73b73334
# URL публичного чата Dify Chatbot (заполнить после создания чатбота)
# См. инструкцию: docs/GUIDE.md — раздел Dify Chatbot
DIFY_CHATBOT_URL=http://84.252.100.93:8080/chat/FILL_AFTER_CHATBOT_CREATED

# --- Summaries Nginx ---
# Раздача .md-файлов саммари (порт 8181)
SUMMARIES_BASE_URL=http://84.252.100.93:8181

# --- Telegram ---
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID
