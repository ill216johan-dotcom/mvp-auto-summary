# ============================================================
# MVP Auto-Summary — Environment Variables
# Copy to .env and fill in actual values:
#   cp .env.example .env
#
# NOTE: open-notebook + SurrealDB удалены 2026-02-26
# Теперь используется Dify.ai для RAG (см. docs/ROADMAP_RAG_UI.md)
# ============================================================

# --- General ---
TIMEZONE=Europe/Moscow

# --- n8n ---
N8N_PORT=5678
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_STRONG_PASSWORD
N8N_ENCRYPTION_KEY=GENERATE_32_CHAR_RANDOM_STRING
N8N_WEBHOOK_URL=http://YOUR_VPS_IP:5678

# --- PostgreSQL ---
POSTGRES_PORT=5432
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=n8n

# --- SpeechKit (Yandex STT) ---
YANDEX_API_KEY=YOUR_YANDEX_API_KEY
TRANSCRIBE_PORT=9001

# --- GLM-4 (ZhipuAI) ---
GLM4_API_KEY=YOUR_ZHIPUAI_API_KEY
GLM4_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM4_MODEL=glm-4.7-flash

# --- Dify.ai (RAG) ---
DIFY_API_KEY=YOUR_DIFY_API_KEY
# LEGACY — общий датасет (ba120e09...). Оставь для fallback.
DIFY_DATASET_ID=ba120e09-0119-438f-b6d6-884e73b73334
# Внутренний URL для n8n (Dify API внутри Docker)
DIFY_BASE_URL=http://84.252.100.93:8080
# Внешний URL Dify Chatbot (для ссылок в Telegram)
DIFY_CHATBOT_URL=http://84.252.100.93:8080

# --- Summaries Nginx ---
# Раздача .md-файлов саммари (порт 8181)
SUMMARIES_BASE_URL=http://84.252.100.93:8181

# --- Telegram ---
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=-1003872092456
