      "parameters": {
        "jsCode": "const updates = $input.first().json.result || [];\nif (updates.length === 0) { return [{ json: { hasCommand: false, chatId: -1003872092456 } }]; }\nconst r = updates.find(u => {\n  const t = (u.message && u.message.text) ? u.message.text.trim() : '';\n  return t === '/report' || t.startsWith('/report@');\n});\nreturn [{ json: { hasCommand: !!r, chatId: r ? r.message.chat.id : -1003872092456 } }];"
      },
