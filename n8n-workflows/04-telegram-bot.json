      "parameters": {
        "jsCode": "const rows = $input.all();\nconst defaultPrompt = \"\\u0422\\u044b \\u0430\\u043d\\u0430\\u043b\\u0438\\u0442\\u0438\\u043a \\u043e\\u0442\\u0434\\u0435\\u043b\\u0430 \\u043a\\u0443\\u0440\\u0430\\u0442\\u043e\\u0440\\u043e\\u0432 \\u0444\\u0443\\u043b\\u0444\\u0438\\u043b\\u043c\\u0435\\u043d\\u0442-\\u043a\\u043e\\u043c\\u043f\\u0430\\u043d\\u0438\\u0438. \\u0422\\u0435\\u0431\\u0435 \\u0434\\u0430\\u044e\\u0442 \\u0442\\u0440\\u0430\\u043d\\u0441\\u043a\\u0440\\u0438\\u043f\\u0442\\u044b \\u0441\\u043e\\u0437\\u0432\\u043e\\u043d\\u043e\\u0432 \\u043a\\u0443\\u0440\\u0430\\u0442\\u043e\\u0440\\u043e\\u0432 \\u0441 \\u043a\\u043b\\u0438\\u0435\\u043d\\u0442\\u0430\\u043c\\u0438 \\u0437\\u0430 \\u0441\\u0435\\u0433\\u043e\\u0434\\u043d\\u044f\\u0448\\u043d\\u0438\\u0439 \\u0434\\u0435\\u043d\\u044c.\\n\\n\\u0421\\u043e\\u0441\\u0442\\u0430\\u0432\\u044c \\u0441\\u0442\\u0440\\u0443\\u043a\\u0442\\u0443\\u0440\\u0438\\u0440\\u043e\\u0432\\u0430\\u043d\\u043d\\u044b\\u0439 \\u041e\\u0422\\u0427\\u0401\\u0422 \\u041f\\u041e \\u041a\\u0423\\u0420\\u0410\\u0422\\u041e\\u0420\\u0410\\u041c:\\n\\n\\u0414\\u043b\\u044f \\u043a\\u0430\\u0436\\u0434\\u043e\\u0433\\u043e \\u043a\\u0443\\u0440\\u0430\\u0442\\u043e\\u0440\\u0430 (\\u0415\\u0432\\u0433\\u0435\\u043d\\u0438\\u0439, \\u041a\\u0440\\u0438\\u0441\\u0442\\u0438\\u043d\\u0430, \\u0410\\u043d\\u043d\\u0430, \\u0413\\u0430\\u043b\\u0438\\u043d\\u0430, \\u0414\\u0430\\u0440\\u044c\\u044f, \\u0421\\u0442\\u0430\\u043d\\u0438\\u0441\\u043b\\u0430\\u0432, \\u0410\\u043d\\u0434\\u0440\\u0435\\u0439), \\u043a\\u0442\\u043e \\u0443\\u043f\\u043e\\u043c\\u0438\\u043d\\u0430\\u0435\\u0442\\u0441\\u044f \\u0432 \\u0441\\u043e\\u0437\\u0432\\u043e\\u043d\\u0430\\u0445:\\n\\n\\ud83d\\udc64 [\\u0418\\u043c\\u044f \\u043a\\u0443\\u0440\\u0430\\u0442\\u043e\\u0440\\u0430]\\n\\u2022 \\u0421\\u043e\\u0437\\u0432\\u043e\\u043d\\u043e\\u0432 \\u0441\\u0435\\u0433\\u043e\\u0434\\u043d\\u044f: N\\n\\u2022 \\u041a\\u043b\\u0438\\u0435\\u043d\\u0442\\u044b: LEAD-XXXX, LEAD-YYYY\\n\\u2022 \\u0420\\u0435\\u0448\\u0451\\u043d\\u043d\\u044b\\u0435 \\u0432\\u043e\\u043f\\u0440\\u043e\\u0441\\u044b: ...\\n\\u2022 \\u041d\\u0435\\u0440\\u0435\\u0448\\u0451\\u043d\\u043d\\u044b\\u0435 \\u0432\\u043e\\u043f\\u0440\\u043e\\u0441\\u044b / \\u0437\\u0430\\u0434\\u0430\\u0447\\u0438: ...\\n\\u2022 \\u0414\\u043e\\u0433\\u043e\\u0432\\u043e\\u0440\\u0451\\u043d\\u043d\\u043e\\u0441\\u0442\\u0438: ...\\n\\n\\u041f\\u0440\\u0430\\u0432\\u0438\\u043b\\u0430:\\n- \\u0412\\u043a\\u043b\\u044e\\u0447\\u0430\\u0439 \\u0442\\u043e\\u043b\\u044c\\u043a\\u043e \\u043a\\u0443\\u0440\\u0430\\u0442\\u043e\\u0440\\u043e\\u0432, \\u043a\\u0442\\u043e \\u0440\\u0435\\u0430\\u043b\\u044c\\u043d\\u043e \\u0443\\u043f\\u043e\\u043c\\u0438\\u043d\\u0430\\u0435\\u0442\\u0441\\u044f \\u0432 \\u0442\\u0440\\u0430\\u043d\\u0441\\u043a\\u0440\\u0438\\u043f\\u0442\\u0430\\u0445\\n- \\u041f\\u0438\\u0448\\u0438 \\u0442\\u043e\\u043b\\u044c\\u043a\\u043e \\u043a\\u043e\\u043d\\u043a\\u0440\\u0435\\u0442\\u043d\\u044b\\u0435 \\u0444\\u0430\\u043a\\u0442\\u044b \\u0438\\u0437 \\u0442\\u0435\\u043a\\u0441\\u0442\\u0430, \\u043d\\u0435 \\u043f\\u0440\\u0438\\u0434\\u0443\\u043c\\u044b\\u0432\\u0430\\u0439\\n- \\u0424\\u043e\\u0440\\u043c\\u0430\\u0442: Markdown\\n- \\u0415\\u0441\\u043b\\u0438 \\u043a\\u0443\\u0440\\u0430\\u0442\\u043e\\u0440\\u0430 \\u043e\\u043f\\u0440\\u0435\\u0434\\u0435\\u043b\\u0438\\u0442\\u044c \\u043d\\u0435\\u0432\\u043e\\u0437\\u043c\\u043e\\u0436\\u043d\\u043e \\u2014 \\u0443\\u043a\\u0430\\u0436\\u0438 '\\u041a\\u0443\\u0440\\u0430\\u0442\\u043e\\u0440 \\u043d\\u0435 \\u043e\\u043f\\u0440\\u0435\\u0434\\u0435\\u043b\\u0451\\u043d' \\u0438 \\u043e\\u043f\\u0438\\u0448\\u0438 \\u0441\\u043e\\u0437\\u0432\\u043e\\u043d \\u043f\\u043e \\u043a\\u043b\\u0438\\u0435\\u043d\\u0442\\u0443\";\nconst meta = $('Aggregate Transcripts').first().json;\nconst promptRow = rows.find(r => r.json && r.json.prompt_text);\nconst systemPrompt = promptRow ? promptRow.json.prompt_text : defaultPrompt;\nreturn [{ json: { ...meta, systemPrompt } }];"
